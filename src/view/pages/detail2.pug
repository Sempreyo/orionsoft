extends ../layouts/default

block vars
	-
		const page = {
			title: 'Оптимизация ресурсов ИТ-инфраструктуры | Orionsoft'
		};

block main
	section.service
		.service__gradient
		.service__poster
			+picture('poster2', 'jpg', 'service__poster-image', '')
			+button('Смотреть фильм', 'service__show', 'https://www.cnews.ru/redirect.php?22869169dfe26276817+kinoland', 'arrow-right')
		.container.service__container
			.service__content
				+button('К афише', 'button--gray service__button', '/#scenario', 'arrow-left')
				.service__rating
					span 10,0
					span Топ-5
				+title('Оптимизируй меня, если сможешь <br> <span>Оптимизация ресурсов ИТ-инфраструктуры</span>', 'service__title')
				.service__description.
					От ИТ-директора все время ускользают ресурсы инфраструктуры, которые он может использовать более эффективно.
					Чтобы поймать их и задействовать на полную мощность, ему придется применить лучшие инструменты управления,
					мониторинга и аналитики. Какое ПО ему в этом поможет?
				.service__roles-label В главных ролях:
				.service__roles
					.role
						+icon('cloudlink', 'role__title')(width='80', height='10')
						span.role__note (CMP-платформа)
					.role
						+icon('zvirt-metrics', 'role__title')(width='45', height='18')
						span.role__note (Аналитика и мониторинг)
					.role
						+icon('zvirt-dcmanager', 'role__title')(width='45', height='19')
						span.role__note (Централизованное управление виртуализацией)
					.role
						+icon('nova-ai', 'role__title')(width='40', height='18')
						span.role__note (Платформа для ИИ)
					.role
						+icon('hyperdrive', 'role__title')(width='90', height='10')
						span.role__note (GitOps-платформа)
				.service__carousel.carousel
					.carousel__slider.swiper
						.swiper-wrapper
							.carousel__slide.swiper-slide
								+title('Материалы о фильме', 'carousel__title')
								+title('Спойлер', 'carousel__title carousel__title--small')
								.carousel__text.
									Компания внедрила платформу для управления инфраструктурой Cloudlink от Orion soft. нагрузка на системы теперь прогнозируемая,
									а бизнес может планировать покупку только необходимого оборудования. Все неиспользуемые ресурсы были пойманы!
							.carousel__slide.swiper-slide
								+title('Материалы о фильме', 'carousel__title')
								+title('Отзыв крупной нефтегазовой компании', 'carousel__title carousel__title--small')
								.carousel__text.
									После внедрения zVirt Metrics и DC Manager мы обнаружили 38% свободных мощностей и не закупили
									лишних серверов — сэкономили 160 млн руб.
							.carousel__slide.carousel__slide--recommends.swiper-slide
								+title('На основе ваших предпочтений:', 'carousel__title')
								.carousel__recommends
									a.recommend-card(href='/main/item/cloud')
										.recommend-card__bg
											+picture('recommend1', 'jpg', 'recommend-card__bg-image', '')
										.recommend-card__title Организация виртуальных рабочих мест
									a.recommend-card(href='/main/item/kii')
										.recommend-card__bg
											+picture('recommend3', 'jpg', 'recommend-card__bg-image', '')
										.recommend-card__title Оптимизация ресурсов ИТ-инфры
						.carousel__pagination.swiper-pagination
					.carousel__nav.swiper-nav
						.swiper-btn-prev
							+icon('arrow-left')(width='14', height='24')
						.swiper-btn-next
							+icon('arrow-right')(width='14', height='24')
				+button('Смотреть фильм', 'service__show service__show--mobile', 'https://www.cnews.ru/redirect.php?22869169dfe26276817+kinoland', 'arrow-right')
				.service__nav
					+button('Предыдущий фильм', 'button--outline service__nav-button service__nav-button--prev', '/main/item/cloud', 'arrow-left')
					+button('Следующий фильм', 'button--outline service__nav-button service__nav-button--next', '/main/item/kii', 'arrow-right')