extends ../layouts/default

block vars
	-
		const page = {
			title: 'Организация виртуальных рабочих мест | Orionsoft'
		};

block main
	section.service
		.service__gradient
		.service__poster
			+picture('poster5', 'jpg', 'service__poster-image', '')
			+button('Смотреть фильм', 'service__show', 'https://www.cnews.ru/redirect.php?48725565045b81a09af+kinoland', 'arrow-right')
		.container.service__container
			.service__content
				+button('К афише', 'button--gray service__button', '/#scenario', 'arrow-left')
				.service__rating
					span 10,0
					span Топ-5
				+title('Остров виртуальных рабочих мест <br> <span>Организация виртуальных рабочих мест</span>', 'service__title')
				.service__description.
					Сотрудник крупной компании отправляется в командировку на удаленный остров в северных морях. Отсутствие стабильной
					связи и большое количество задач чуть не сводит его с ума. Компании срочно нужно решение, для организации удаленной
					работы, чтобы не потерять сотрудника и не увеличить нагрузку на инфраструктуру.
				.service__roles-label В главных ролях:
				.service__roles
					.role
						+icon('zvirt', 'role__title')(width='45', height='10')
						span.role__note (Виртуализация)
					.role
						+icon('termit', 'role__title')(width='56', height='10')
						span.role__note (Виртуальные рабочие столы (VDI))
				.service__carousel.carousel
					.carousel__slider.swiper
						.swiper-wrapper
							.carousel__slide.swiper-slide
								+title('Материалы о фильме', 'carousel__title')
								+title('Спойлер', 'carousel__title carousel__title--small')
								.carousel__text.
									Компания внедряет VDI Termit на базе виртуализации zVirt. Решение помогает сотруднику решить все нужные
									задачи в корпоративных системах прямо с острова и вернуться домой, сохранив рассудок.
							.carousel__slide.swiper-slide
								+title('Материалы о фильме', 'carousel__title')
								+title('Отзыв крупной транспортной компании', 'carousel__title carousel__title--small')
								.carousel__text.
									Теперь наши сотрудники могут одинаково эффективно работать из любой локации: офис, дом, командировка.
									Рабочие системы, например 1С, доступны им на любом устройстве, вплоть до планшетов. Так мы значительно
									сократили время развертывания рабочих мест: с 1 часа до нескольких минут. Теперь — тысячи сразу можно
									создать из одного “золотого образа”.
							.carousel__slide.carousel__slide--recommends.swiper-slide
								+title('На основе ваших предпочтений:', 'carousel__title')
								.carousel__recommends
									a.recommend-card(href='/main/item/ai')
										.recommend-card__bg
											+picture('recommend4', 'jpg', 'recommend-card__bg-image', '')
										.recommend-card__title Организация виртуальных рабочих мест
									a.recommend-card(href='/main/item/cloud')
										.recommend-card__bg
											+picture('recommend1', 'jpg', 'recommend-card__bg-image', '')
										.recommend-card__title Оптимизация ресурсов ИТ-инфры
						.carousel__pagination.swiper-pagination
					.carousel__nav.swiper-nav
						.swiper-btn-prev
							+icon('arrow-left')(width='14', height='24')
						.swiper-btn-next
							+icon('arrow-right')(width='14', height='24')
				+button('Смотреть фильм', 'service__show service__show--mobile', 'https://www.cnews.ru/redirect.php?48725565045b81a09af+kinoland', 'arrow-right')
				.service__nav
					+button('Предыдущий фильм', 'button--outline service__nav-button service__nav-button--prev', '/main/item/ai', 'arrow-left')
					+button('Следующий фильм', 'button--outline service__nav-button service__nav-button--next', '/main/item/cloud', 'arrow-right')