extends ../layouts/default

block vars
	-
		const page = {
			title: 'Частное облако | Orionsoft'
		};

block main
	section.service
		.service__gradient
		.service__poster
			+picture('poster1', 'jpg', 'service__poster-image', '')
			+button('Смотреть фильм', 'service__show', '#', 'arrow-right')
		.container.service__container
			.service__content
				+button('К афише', 'button--gray service__button', '/#scenario', 'arrow-left')
				.service__rating
					span 10,0
					span Топ-5
				+title('Частное облако с Уолл-стрит <br> <span>Orion private cloud</span>', 'service__title')
				.service__description.
					Выдача ресурсов в ИТ-инфраструктуре напоминает оживленные торги на Уолл-стрит – сроки горят, управлять
					процессом сложно, прогнозирование стоимости владения ИТ практически невозможно.
				.service__roles-label В главных ролях:
				.service__roles
					.role
						+icon('zvirt', 'role__title')(width='45', height='10')
						span.role__note (Виртуализация)
					.role
						+icon('nova', 'role__title')(width='37', height='10')
						span.role__note (Контейнеры)
					.role
						+icon('cloudlink', 'role__title')(width='80', height='10')
						span.role__note (CMP-платформа)
					.role
						+icon('starvault', 'role__title')(width='84', height='10')
						span.role__note (Управление секретами)
				.service__carousel.carousel
					.carousel__slider.swiper
						.swiper-wrapper
							.carousel__slide.swiper-slide
								+title('Материалы о фильме', 'carousel__title')
								+title('Спойлер', 'carousel__title carousel__title--small')
								.carousel__text.
									Компания развернула частное облако Orion Private Cloud. С его помощью бизнес сможет лучше контролировать инфраструктуру
									и сэкономит до 200% средств на закупках оборудования. Возврат нагрузок из публичных облаков снизит затраты еще на 30%.
							.carousel__slide.swiper-slide
								+title('Материалы о фильме', 'carousel__title')
								+title('Отзыв крупной финансовой организации', 'carousel__title carousel__title--small')
								.carousel__text.
									Сюжет закончился «хэппи-эндом»: компания внедрила Orion Private Cloud с доказанным сокращением TCO. А еще мы получили
									сервис управления ресурсами по принципу маркетплейса, где выдать мощности под задачу так же легко, как заказать товар.
							.carousel__slide.carousel__slide--recommends.swiper-slide
								+title('На основе ваших предпочтений:', 'carousel__title')
								.carousel__recommends
									a.recommend-card(href='/main/item/workplaces')
										.recommend-card__bg
											+picture('recommend5', 'jpg', 'recommend-card__bg-image', '')
										.recommend-card__title Организация виртуальных рабочих мест
									a.recommend-card(href='/main/item/optimization')
										.recommend-card__bg
											+picture('recommend2', 'jpg', 'recommend-card__bg-image', '')
										.recommend-card__title Оптимизация ресурсов ИТ-инфры
						.carousel__pagination.swiper-pagination
					.carousel__nav.swiper-nav
						.swiper-btn-prev
							+icon('arrow-left')(width='14', height='24')
						.swiper-btn-next
							+icon('arrow-right')(width='14', height='24')
				+button('Смотреть фильм', 'service__show service__show--mobile', '#', 'arrow-right')
				.service__nav
					+button('Предыдущий фильм', 'button--outline service__nav-button service__nav-button--prev', '/main/item/workplaces', 'arrow-left')
					+button('Следующий фильм', 'button--outline service__nav-button service__nav-button--next', '/main/item/optimization', 'arrow-right')