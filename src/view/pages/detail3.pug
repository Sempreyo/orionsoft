extends ../layouts/default

block vars
	-
		const page = {
			title: 'Защищенная инфраструктура под КИИ | Orionsoft'
		};

block main
	section.service
		.service__gradient
		.service__poster
			+picture('poster3', 'jpg', 'service__poster-image', '')
			+button('Смотреть фильм', 'service__show', 'https://www.cnews.ru/redirect.php?63157669dfe297e8231+kinoland', 'arrow-right')
		.container.service__container
			.service__content
				+button('К афише', 'button--gray service__button', '/#scenario', 'arrow-left')
				.service__rating
					span 10,0
					span Топ-5
				+title('Выживший с КИИ <br> <span>Защищенная инфраструктура под КИИ</span>', 'service__title')
				.service__description.
					Число атак на инфраструктуру российских компаний постоянно растет, а злоумышленники все время ищут новые методы проникновения.
					Чтобы защититься и выжить, компании нужно обеспечить надежную защиту на уровне инфраструктуры по требованиям законов о КИИ, ГИС и персональных данных.
				.service__roles-label В главных ролях:
				.service__roles
					.role
						+icon('zvirt-max', 'role__title')(width='45', height='19')
						span.role__note (Виртуализация ФСТЭК)
					.role
						+icon('nova-se', 'role__title')(width='40', height='19')
						span.role__note (Контейнеры ФСТЭК)
					.role
						+icon('starvault', 'role__title')(width='84', height='10')
						span.role__note (Управление секретами)
					.role
						+icon('cloudlink', 'role__title')(width='80', height='10')
						span.role__note (CMP-платформа)
				.service__carousel.carousel
					.carousel__slider.swiper
						.swiper-wrapper
							.carousel__slide.swiper-slide
								+title('Материалы о фильме', 'carousel__title')
								+title('Спойлер', 'carousel__title carousel__title--small')
								.carousel__text.
									Компания внедрила комплекс решений Orion soft: виртуализацию, платформу оркестрации контейнеров и хранилище секретов.
									Продукты сертифицированы ФСТЭК и приводят инфраструктуру в соответствие требованиям законодательства.
							.carousel__slide.swiper-slide
								+title('Материалы о фильме', 'carousel__title')
								+title('Отзыв крупной государственной компании', 'carousel__title carousel__title--small')
								.carousel__text.
									Мы обеспечили соблюдение всех требований регулятора по работе с критической инфраструктурой и персональными данными.
									С решениями Orion soft мы без проблем прошли аттестацию по требованиям ФСТЭК и укрепили защиту инфраструктуры
							.carousel__slide.carousel__slide--recommends.swiper-slide
								+title('На основе ваших предпочтений:', 'carousel__title')
								.carousel__recommends
									a.recommend-card(href='/main/item/optimization')
										.recommend-card__bg
											+picture('recommend2', 'jpg', 'recommend-card__bg-image', '')
										.recommend-card__title Организация виртуальных рабочих мест
									a.recommend-card(href='/main/item/ai')
										.recommend-card__bg
											+picture('recommend4', 'jpg', 'recommend-card__bg-image', '')
										.recommend-card__title Оптимизация ресурсов ИТ-инфры
						.carousel__pagination.swiper-pagination
					.carousel__nav.swiper-nav
						.swiper-btn-prev
							+icon('arrow-left')(width='14', height='24')
						.swiper-btn-next
							+icon('arrow-right')(width='14', height='24')
				+button('Смотреть фильм', 'service__show service__show--mobile', 'https://www.cnews.ru/redirect.php?63157669dfe297e8231+kinoland', 'arrow-right')
				.service__nav
					+button('Предыдущий фильм', 'button--outline service__nav-button service__nav-button--prev', '/main/item/optimization', 'arrow-left')
					+button('Следующий фильм', 'button--outline service__nav-button service__nav-button--next', '/main/item/ai', 'arrow-right')